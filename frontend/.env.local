# Auth key — must match DASHBOARD_KEY in start_all.sh / dashboard/app.py
NEXT_PUBLIC_DASHBOARD_KEY=dashboard_secret_2026

# Backend URL used by the Next.js server-side rewrite proxy.
# Always points to the Flask dashboard on the SAME machine (localhost).
# Remote browsers reach the backend via the Next.js proxy, not directly.
BACKEND_URL=http://localhost:8080
